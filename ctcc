#!/usr/bin/env python3
"""
CTCC — Computer to Computer Communication
Relay Server + DuckDNS auto-updater

Usage:
  ctcc server       — start the relay server (your machine)
  ctcc connect      — connect via internet (ctccserver.duckdns.org)
  ctcc join <IP>    — connect via local network
"""

import socket
import threading
import sys
import os
import hashlib
import urllib.request
import time
from datetime import datetime

# ── config ────────────────────────────────────────────────────
PORT          = 5050
BUFFER        = 4096
PW_HASH       = "0fe01a211ae14008fd9bccac52a0317011d5af4f2331d0cdbe30d7e61a45f79c"
DUCKDNS_TOKEN = "c84cf036-b3c1-4c51-a1a9-56d98b0b2f4a"
DUCKDNS_SUB   = "ctccserver"
PUBLIC_HOST   = "ctccserver.duckdns.org"

# ── colours ──────────────────────────────────────────────────
R   = '\033[1;31m'
Y   = '\033[1;33m'
G   = '\033[1;32m'
C   = '\033[1;36m'
W   = '\033[1;37m'
DIM = '\033[2m'
RST = '\033[0m'

LOGO = f"""
{R} ██████╗{Y}████████╗{G} ██████╗{C} ██████╗{RST}
{R}██╔════╝{Y}╚══██╔══╝{G}██╔════╝{C}██╔════╝{RST}
{R}██║     {Y}   ██║   {G}██║     {C}██║     {RST}
{R}██║     {Y}   ██║   {G}██║     {C}██║     {RST}
{R}╚██████╗{Y}   ██║   {G}╚██████╗{C}╚██████╗{RST}
{R} ╚═════╝{Y}   ╚═╝   {G} ╚═════╝{C} ╚═════╝{RST}
{DIM}   Computer to Computer Communication{RST}
"""

# ── helpers ──────────────────────────────────────────────────
def ts():
    return datetime.now().strftime('%H:%M:%S')

def clear():
    os.system('cls' if os.name == 'nt' else 'clear')

def hash_pw(pw):
    return hashlib.sha256(pw.encode()).hexdigest()

def get_local_ip():
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        s.connect(('10.255.255.255', 1))
        ip = s.getsockname()[0]
        if ip and not ip.startswith('127.'):
            return ip
    except Exception:
        pass
    finally:
        s.close()
    try:
        for info in socket.getaddrinfo(socket.gethostname(), None):
            ip = info[4][0]
            if ':' not in ip and not ip.startswith('127.'):
                return ip
    except Exception:
        pass
    for target in ('192.168.1.1', '10.0.0.1', '172.16.0.1'):
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect((target, 80))
            ip = s.getsockname()[0]
            s.close()
            if ip and not ip.startswith('127.'):
                return ip
        except Exception:
            pass
    return '127.0.0.1'

def sys_print(text, name=None):
    print(f"\r{DIM}[{ts()}]{RST} {Y}** {text} **{RST}")
    if name:
        reprint_prompt(name)

def chat_print(sender, text, color, my_name):
    print(f"\r{DIM}[{ts()}]{RST} {color}{sender}{RST}: {text}")
    reprint_prompt(my_name)

def reprint_prompt(name):
    print(f"{C}{name}{RST} > ", end='', flush=True)

# ═══════════════════════════════════════════════════════════════
#   DUCKDNS AUTO-UPDATER
# ═══════════════════════════════════════════════════════════════

def update_duckdns():
    url = f"https://www.duckdns.org/update?domains={DUCKDNS_SUB}&token={DUCKDNS_TOKEN}&ip="
    try:
        res = urllib.request.urlopen(url, timeout=10).read().decode().strip()
        if res == "OK":
            print(f"{DIM}[{ts()}]{RST} {G}** DuckDNS updated: {PUBLIC_HOST} **{RST}")
        else:
            print(f"{DIM}[{ts()}]{RST} {R}** DuckDNS update failed: {res} **{RST}")
    except Exception as e:
        print(f"{DIM}[{ts()}]{RST} {R}** DuckDNS error: {e} **{RST}")

def duckdns_loop():
    while True:
        update_duckdns()
        time.sleep(300)  # update every 5 minutes

# ═══════════════════════════════════════════════════════════════
#   RELAY SERVER
# ═══════════════════════════════════════════════════════════════

clients      = {}
clients_lock = threading.Lock()

def broadcast(msg, exclude=None):
    with clients_lock:
        for sock in list(clients):
            if sock is exclude:
                continue
            try:
                sock.sendall(msg.encode())
            except Exception:
                pass

def kick_client(sock):
    with clients_lock:
        name = clients.pop(sock, 'unknown')
    try:
        sock.close()
    except Exception:
        pass
    return name

def handle_client(conn, addr):
    try:
        conn.sendall(b"PW?")
        pw = conn.recv(BUFFER).decode().strip()
        if hash_pw(pw) != PW_HASH:
            conn.sendall(b"DENIED")
            conn.close()
            print(f"{DIM}[{ts()}]{RST} {R}** Rejected {addr[0]} — wrong password **{RST}")
            return
        conn.sendall(b"OK")

        raw = conn.recv(BUFFER).decode().strip()
        if not raw.startswith("NAME:"):
            conn.close()
            return
        name = raw[5:].strip() or addr[0]
    except Exception:
        conn.close()
        return

    with clients_lock:
        clients[conn] = name

    print(f"{DIM}[{ts()}]{RST} {G}** {name} joined from {addr[0]} **{RST}")
    broadcast(f"SYS:{name} joined the room.", exclude=conn)
    conn.sendall(b"SYS:Welcome to CTCC! Type /quit to leave.")

    while True:
        try:
            data = conn.recv(BUFFER)
            if not data:
                break
            text = data.decode().strip()
            print(f"{DIM}[{ts()}]{RST} {G}{name}{RST}: {text}")
            broadcast(f"MSG:{name}:{text}", exclude=conn)
        except Exception:
            break

    left = kick_client(conn)
    print(f"{DIM}[{ts()}]{RST} {Y}** {left} left **{RST}")
    broadcast(f"SYS:{left} left the room.")

def server_command_loop():
    while True:
        try:
            cmd = input()
        except (EOFError, KeyboardInterrupt):
            broadcast("SYS:Server is shutting down.")
            print(f"\n{Y}** Server shutting down. **{RST}")
            os._exit(0)

        if cmd.startswith("/kick "):
            target = cmd[6:].strip()
            with clients_lock:
                found = {s: n for s, n in clients.items() if n == target}
            if found:
                for s in found:
                    s.sendall(b"KICKED")
                    kick_client(s)
                broadcast(f"SYS:{target} was kicked.")
                print(f"{Y}** Kicked {target} **{RST}")
            else:
                print(f"{R}** No user named '{target}' **{RST}")

        elif cmd.strip() == "/list":
            with clients_lock:
                names = list(clients.values())
            print(f"{Y}** Online: {', '.join(names) if names else 'nobody'} **{RST}")

        elif cmd.strip() in ("/quit", "/q"):
            broadcast("SYS:Server is shutting down.")
            print(f"{Y}** Server shutting down. **{RST}")
            os._exit(0)

        elif cmd.strip():
            broadcast(f"MSG:[SERVER]:{cmd}")

def run_server():
    clear()
    print(LOGO)
    print(f"{Y}** Starting CTCC Relay Server **{RST}\n")

    threading.Thread(target=duckdns_loop, daemon=True).start()

    local_ip = get_local_ip()
    srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    srv.bind(('', PORT))
    srv.listen(20)

    print(f"{G}** Server running on port {PORT} **{RST}")
    print(f"{G}** Local:    {W}{local_ip}:{PORT}{RST}")
    print(f"{G}** Internet: {W}{PUBLIC_HOST}:{PORT}{RST}")
    print(f"{DIM}   Make sure port {PORT} is forwarded on your router!{RST}")
    print(f"{DIM}   Commands: /kick <name>  /list  /quit{RST}\n")

    def accept_loop():
        while True:
            try:
                conn, addr = srv.accept()
                threading.Thread(target=handle_client, args=(conn, addr), daemon=True).start()
            except Exception:
                break

    threading.Thread(target=accept_loop, daemon=True).start()
    server_command_loop()

# ═══════════════════════════════════════════════════════════════
#   CLIENT
# ═══════════════════════════════════════════════════════════════

def client_recv_loop(sock, my_name):
    while True:
        try:
            data = sock.recv(BUFFER)
            if not data:
                sys_print("Connection closed.", my_name)
                os._exit(0)
            text = data.decode().strip()
            if text == "KICKED":
                print(f"\r{R}** You were kicked. **{RST}")
                os._exit(0)
            elif text.startswith("SYS:"):
                sys_print(text[4:], my_name)
            elif text.startswith("MSG:"):
                parts = text[4:].split(":", 1)
                sender = parts[0] if len(parts) == 2 else "?"
                body   = parts[1] if len(parts) == 2 else text
                chat_print(sender, body, G, my_name)
        except Exception:
            sys_print("Lost connection.", my_name)
            os._exit(0)

def client_send_loop(sock, my_name):
    reprint_prompt(my_name)
    while True:
        try:
            msg = input()
        except (EOFError, KeyboardInterrupt):
            print(f"\n{Y}** Disconnected. **{RST}")
            sock.close()
            sys.exit(0)

        if not msg.strip():
            reprint_prompt(my_name)
            continue

        if msg.strip() in ("/quit", "/q"):
            print(f"{Y}** Disconnected. **{RST}")
            sock.close()
            sys.exit(0)

        try:
            sock.sendall(msg.encode())
        except Exception:
            print(f"{R}** Send failed. **{RST}")
            sys.exit(1)

        print(f"\033[1A\r{DIM}[{ts()}]{RST} {C}{my_name}{RST}: {msg}")
        reprint_prompt(my_name)

def do_join(host, my_name):
    import getpass
    print(f"{C}** Connecting to {host}:{PORT}... **{RST}")
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(15)
    try:
        sock.connect((host, PORT))
    except ConnectionRefusedError:
        print(f"{R}** Could not connect. Is the server running? **{RST}")
        sys.exit(1)
    except socket.gaierror:
        print(f"{R}** Could not resolve '{host}'. Check the address. **{RST}")
        sys.exit(1)
    except (TimeoutError, socket.timeout):
        print(f"{R}** Connection timed out. The server may be offline or the port is blocked. **{RST}")
        sys.exit(1)
    except OSError as exc:
        print(f"{R}** Network error: {exc} **{RST}")
        sys.exit(1)

    challenge = sock.recv(BUFFER)
    if challenge != b"PW?":
        print(f"{R}** Unexpected response. **{RST}")
        sys.exit(1)

    pw = getpass.getpass("Room password: ")
    sock.sendall(pw.encode())

    resp = sock.recv(BUFFER)
    if resp == b"DENIED":
        print(f"{R}** Wrong password. **{RST}")
        sys.exit(1)

    sock.sendall(f"NAME:{my_name}".encode())
    sock.settimeout(None)
    print(f"{G}** Connected! Type messages below. /quit to leave. **{RST}\n")

    threading.Thread(target=client_recv_loop, args=(sock, my_name), daemon=True).start()
    client_send_loop(sock, my_name)

def run_join(host):
    clear()
    print(LOGO)
    my_name = input("Your name: ").strip() or socket.gethostname()
    print()
    do_join(host, my_name)

def run_connect():
    clear()
    print(LOGO)
    my_name = input("Your name: ").strip() or socket.gethostname()
    print()
    do_join(PUBLIC_HOST, my_name)

# ═══════════════════════════════════════════════════════════════
#   ENTRY
# ═══════════════════════════════════════════════════════════════

def usage():
    print(LOGO)
    print(f"  {W}ctcc server{RST}            — start the relay server")
    print(f"  {W}ctcc connect{RST}           — connect via internet")
    print(f"  {W}ctcc join <IP>{RST}         — connect via local network\n")
    sys.exit(0)

if __name__ == '__main__':
    args = sys.argv[1:]

    if not args or args[0] in ('-h', '--help', 'help'):
        usage()
    elif args[0] == 'server':
        run_server()
    elif args[0] == 'connect':
        run_connect()
    elif args[0] == 'join':
        if len(args) < 2:
            print(f"{R}Usage: ctcc join <IP>{RST}")
            sys.exit(1)
        run_join(args[1])
    else:
        print(f"{R}Unknown command: {args[0]}{RST}")
        usage()
